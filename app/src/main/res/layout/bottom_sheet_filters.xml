<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minHeight="400dp"
    android:padding="16dp"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filtri e Ordinamento"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <!-- Audio Locale Filter -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lingua Audio:"
            android:textStyle="bold"
            android:paddingTop="8dp" />

        <Spinner
            android:id="@+id/audioLocaleSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingTop="4dp" />

        <!-- Min Rating Filter -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rating Minimo:"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <TextView
            android:id="@+id/ratingValueText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tutti"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/minRatingSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="50"
            android:progress="0" />

        <!-- Sort Option -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ordinamento:"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <Spinner
            android:id="@+id/sortBySpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingTop="4dp" />

        <!-- Platform Filter -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Piattaforma:"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <Spinner
            android:id="@+id/platformSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingTop="4dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="24dp"
            android:gravity="end">

            <Button
                android:id="@+id/clearFiltersButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset"
                android:layout_marginEnd="8dp"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/applyFiltersButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Applica" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
